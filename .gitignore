# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# SQLite (local dev only)
*.db
*.db-shm
*.db-wal

# DB backups written by scripts/ before a destructive run — these dump every
# table, including player_auth PIN hashes. Never commit them.
backup-*.json

# throwaway one-off DB inspection scripts
scripts/tmp-*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# local verification artifacts + import backups (see scripts/snapshot-handicaps.mjs)
/.snapshots/
/backup-before-*.json
